# RCV Voting Simulator Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to version control

# Default seed for random number generation
# Leave empty for a random seed on each load, or set a specific seed for consistent results
# Example: VITE_DEFAULT_SEED=abc123
VITE_DEFAULT_SEED=

# Default number of simulated voters
# Range: 100-50000 (recommended: 5000-10000 for good performance)
VITE_DEFAULT_VOTER_COUNT=5000

# Enable debug mode (shows additional logging in console)
VITE_DEBUG_MODE=false

# Analytics/Tracking (optional)
# Google Analytics 4 Measurement ID
VITE_GA_TRACKING_ID=
# Plausible Analytics domain
VITE_PLAUSIBLE_DOMAIN=

# API endpoints (for future backend features)
VITE_API_BASE_URL=
VITE_API_KEY=

# Feature flags
VITE_ENABLE_SHARE_BUTTON=true
VITE_ENABLE_EXPORT_RESULTS=false
VITE_ENABLE_CUSTOM_CANDIDATES=false

# Simulation limits
VITE_MAX_CANDIDATES=10
VITE_MIN_CANDIDATES=3
VITE_MAX_VOTER_COUNT=50000
VITE_MIN_VOTER_COUNT=100

# UI Configuration
VITE_SHOW_TIE_BREAKER_INFO=true
VITE_ANIMATE_TRANSITIONS=true
# Color schemes: default, colorblind, highcontrast
VITE_CHART_COLOR_SCHEME=default

# Deployment-specific
# The public URL where the app will be hosted (optional)
VITE_PUBLIC_URL=
# Custom site title
VITE_SITE_TITLE=Fort Collins RCV Voting Simulator
# SEO meta description
VITE_META_DESCRIPTION=Interactive ranked choice voting simulator for Fort Collins elections
